rules_version = '2';

// Phase 0 rules cover the user profile. Phase 1 adds read access to lobby
// docs + the players subcollection for anyone who has joined the lobby.
// All lobby/player writes go through Cloud Functions (createLobby,
// joinLobby, startRound, submitTag) using the Admin SDK, which bypasses
// these rules. Tag rules land in Phase 2. Default-deny for anything not
// explicitly allowed here.
service cloud.firestore {
  match /databases/{database}/documents {

    function isPlayerOf(lobbyId) {
      return request.auth != null && exists(
        /databases/$(database)/documents/lobbies/$(lobbyId)/players/$(request.auth.uid)
      );
    }

    function isValidUserProfile(data) {
      return data.keys().hasOnly([
          'displayName',
          'faceEmbedding',
          'embeddingModelVersion',
          'createdAt',
        ])
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 20
        && data.faceEmbedding is list
        && data.faceEmbedding.size() == 128
        && data.embeddingModelVersion is string
        && data.embeddingModelVersion.size() > 0
        && data.createdAt is timestamp;
    }

    // users/{uid}: a player's profile, including their face embedding.
    // Only the owner reads or writes their own doc. The deleteUserData
    // Cloud Function uses the Admin SDK and bypasses these rules.
    //
    // Schema mirrors lib/models/user_profile.dart — bump both together.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && isValidUserProfile(request.resource.data);
    }

    // lobbies/{lobbyId}: the round-level state doc. Readable by anyone who
    // already has a player record in the lobby — the client subscribes to
    // this for the waiting-room screen and (Phase 2+) live round status.
    // All writes are server-side via the Admin SDK.
    match /lobbies/{lobbyId} {
      allow read: if isPlayerOf(lobbyId);
      allow write: if false;

      // lobbies/{lobbyId}/players/{uid}: per-player state. Same read rule —
      // a player can see the rest of the room (and themselves). The host's
      // creation and joiners' writes both happen through the corresponding
      // Cloud Function, so no client write path is needed here either.
      match /players/{uid} {
        allow read: if isPlayerOf(lobbyId);
        allow write: if false;
      }

      // lobbies/{lobbyId}/tags/{tagId}: tag records. Read access mirrors the
      // rest of the lobby — players see each other's tag history (used by
      // the scoreboard / end-of-round summary in Phase 2). Writes are
      // server-only via submitTag (Phase 2).
      match /tags/{tagId} {
        allow read: if isPlayerOf(lobbyId);
        allow write: if false;
      }
    }

    // Default deny everything else until Phase 2 lands.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
