rules_version = '2';

// Phase 0 rules cover onboarding selfies. Tag photo rules per §5.9 land in
// PR #3 of Phase 2 (alongside submitTag). Default-deny for anything not
// explicitly allowed here.
service firebase.storage {
  match /b/{bucket}/o {

    // selfies/{uid}.jpg: only the owner reads or writes their own selfie.
    // Path is bound by fileName so we can assert the full filename matches
    // <uid>.jpg (the wildcard would otherwise match any object name).
    // Client deletes are denied — deleteUserData (Admin SDK) handles cleanup.
    match /selfies/{fileName} {
      allow read: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
      allow create, update: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size <= 1 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
